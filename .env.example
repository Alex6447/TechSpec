# ============================================================
# Telegram
# ============================================================
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ============================================================
# Database
# ============================================================
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/b2c_db

# ============================================================
# Security
# ============================================================
# 32-byte master key in base64 — used to encrypt RSA keys and access tokens at rest
# Generate: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
MASTER_KEY=base64-encoded-256bit-key-here

# Static token for X-Admin-Token header (Admin API protection)
ADMIN_TOKEN=your_secret_admin_token_here

# ============================================================
# Application
# ============================================================
APP_HOST=0.0.0.0
APP_PORT=8000

# Base URL for TWA (Telegram Web App) card details links
TWA_BASE_URL=https://your-domain.com

# ============================================================
# Arqen B2B Platform
# ============================================================
# Sandbox: https://sandbox.arqen.finance
# Production: https://arqen.finance
ARQEN_BASE_URL=https://sandbox.arqen.finance
